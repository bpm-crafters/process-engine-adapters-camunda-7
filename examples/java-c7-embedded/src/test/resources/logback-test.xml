<configuration>
  <appender name="STDOUT" class="ch.qos.logback.core.ConsoleAppender">
    <encoder>
      <pattern>%d{HH:mm:ss.SSS} [%thread] %-5level %logger{36} - %msg%n</pattern>
    </encoder>
  </appender>

  <root level="INFO">
    <appender-ref ref="STDOUT"/>
  </root>

  <logger name="dev.bpmcrafters" level="INFO"/>
  <logger name="dev.bpmcrafters.processengineapi.adapter.c7.embedded.task.delivery.pull" level="TRACE"/>
  <logger name="org.camunda.bpm.engine" level="INFO"/>

</configuration>
